# QC Marketing Bot - Settings
# Copy file ini jadi `config.txt` lalu adjust nilai sesuai kebutuhan.

# Threshold publish (skor rata-rata)
THRESHOLD=75

# Active AI model. Pilihan:
#   claude-opus-4-7         (Claude Opus 4.7 — smart, mahal)
#   claude-sonnet-4-6       (Claude Sonnet 4.6 — recommended)
#   claude-haiku-4-5-20251001 (Claude Haiku 4.5 — cepat)
#   gemini-2.5-pro          (Gemini 2.5 Pro — smart, video native)
#   gemini-2.5-flash        (Gemini 2.5 Flash — paling murah)
CLAUDE_MODEL=claude-sonnet-4-6
MAX_OUTPUT_TOKENS=8000

# Web search (verifikasi fakta)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_USES=5

# Adaptive backoff polling
POLLING_BASE_SEC=30
POLLING_MAX_SEC=600
POLLING_STEP_SEC=10

# Image processing
IMAGE_MAX_DIMENSION=1568

# Video frame extraction (butuh ffmpeg di tools/ffmpeg/ atau PATH)
VIDEO_FRAME_INTERVAL_SEC=5
VIDEO_MAX_FRAMES=15
VIDEO_MAX_BYTES=209715200

LOG_RETENTION_DAYS=120
